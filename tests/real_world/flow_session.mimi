// MCDD real_world: Session Types — dual-endpoint runtime (v0.29.34)
// Declares a linear session protocol and exercises send/recv/close
// with actual channel communication (not just static order check).
// session_pair() returns two cross-wired channels:
//   pair[0] (lo) and pair[1] (hi) are cross-wired:
//   send on [0] → recv on [1]; send on [1] → recv on [0].

session ClientProto = !i32 . ?i32 . end
session ServerProto = dual(ClientProto)

func main() -> i32 {
    let pair = session_pair()
    let ch0 = pair[0]
    let ch1 = pair[1]

    // Client sends 10 on ch0 → server receives on ch1
    session_send(ch0, 10)
    let n = session_recv(ch1)
    // Server sends n+1 on ch1 → client receives on ch0
    session_send(ch1, n + 1)
    let reply = session_recv(ch0)
    session_close(ch0)
    session_close(ch1)

    println(n)
    println(reply)
    0
}
