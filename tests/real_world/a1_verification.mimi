// A1 i32/i64 verification: exercise all codegen paths affected by i32→i64 separation.
// Every test case uses i32 parameters in trait impls, closures, and function calls
// to ensure no physreg copy errors or silent miscompilation.

use std::strings
use std::collections

// ── Test 1: String trait methods with i32 params ──
// repeat(n: i32), substring(start: i32, end: i32), char_at(index: i32)
func test_string_trait_i32() -> i32 {
    let s = "hello"
    // These call trait impl methods where params are i32
    let r = s.repeat(3)
    if r != "hellohellohello" { return 1 }
    let sub = s.substring(1, 4)
    if sub != "ell" { return 2 }
    let c = s.char_at(0)
    if c != "h" { return 3 }
    let idx = s.index_of("ll")
    match idx {
        Some(i) => { if i != 2 { return 4 } }
        None => { return 5 }
    }
    0
}

// ── Test 2: Collections with i32 trait params ──
// take(n: i32) — i32 param in generic trait method
func test_collections_i32() -> i32 {
    let xs = [10, 20, 30, 40, 50]
    let first2 = xs.take(2)
    if len(first2) != 2 { return 1 }
    0
}

// ── Test 3: map_list/filter_list with i32 closures ──
func test_map_filter_i32() -> i32 {
    let xs = [1, 2, 3, 4, 5]
    let doubled = map_list(xs, fn(x: i32) -> i32 { x * 2 })
    if doubled[0] != 2 || doubled[4] != 10 { return 1 }
    let evens = filter_list(xs, fn(x: i32) -> bool { x % 2 == 0 })
    if len(evens) != 2 { return 2 }
    let total = reduce_list(xs, fn(a: i32, b: i32) -> i32 { a + b }, 0)
    if total != 15 { return 3 }
    0
}

// ── Test 4: i32 arithmetic in functions ──
func compute(x: i32, y: i32) -> i32 {
    let a = x + y
    let b = a * 2
    let c = b - x
    c
}

func test_i32_arithmetic() -> i32 {
    if compute(3, 4) != 11 { return 1 }
    if compute(0, 0) != 0 { return 2 }
    if compute(-5, 10) != 15 { return 3 }
    0
}

// ── Test 5: i32 in Result/Option ──
func test_i32_result_option() -> i32 {
    let r = Ok(42)
    match r {
        Ok(v) => { if v != 42 { return 1 } }
        Err(_) => { return 2 }
    }
    let o = Some(99)
    match o {
        Some(v) => { if v != 99 { return 3 } }
        None => { return 4 }
    }
    0
}

// ── Test 6: String operations from stdlib ──
func test_stdlib_strings() -> i32 {
    let s = "  hello world  "
    let t = trim(s)
    if t != "hello world" { return 1 }
    let parts = split(t, " ")
    if len(parts) != 2 { return 2 }
    let joined = join(parts, "-")
    if joined != "hello-world" { return 3 }
    let up = to_upper(joined)
    if up != "HELLO-WORLD" { return 4 }
    0
}

// ── Test 7: Mixed i32/i64 operations ──
func test_mixed_widths() -> i32 {
    let small: i32 = 100
    let big: i64 = 1000000
    let sum_i32 = small + 200
    if sum_i32 != 300 { return 1 }
    // i64 operations should still work independently
    if big + 1 != 1000001 { return 2 }
    0
}

// ── Test 8: Struct fields with i32 ──
type Point { x: i32, y: i32 }

func test_struct_i32() -> i32 {
    let p = Point { x: 10, y: 20 }
    if p.x != 10 || p.y != 20 { return 1 }
    let moved = Point { x: p.x + 5, y: p.y - 5 }
    if moved.x != 15 || moved.y != 15 { return 2 }
    0
}

// ── Test 9: List trait methods with i32 params ──
func test_slice_i32() -> i32 {
    let xs = [10, 20, 30, 40, 50]
    let sub = xs.take(3)
    if len(sub) != 3 { return 1 }
    if sub[0] != 10 || sub[2] != 30 { return 2 }
    0
    0
}

// ── Test 10: for loop with i32 range ──
func test_for_range_i32() -> i32 {
    let mut sum = 0
    for i in range(0, 10) {
        sum = sum + i
    }
    if sum != 45 { return 1 }
    0
}

func main() -> i32 {
    if test_string_trait_i32() != 0 { return 1 }
    if test_collections_i32() != 0 { return 2 }
    if test_map_filter_i32() != 0 { return 3 }
    if test_i32_arithmetic() != 0 { return 4 }
    if test_i32_result_option() != 0 { return 5 }
    if test_stdlib_strings() != 0 { return 6 }
    if test_mixed_widths() != 0 { return 7 }
    if test_struct_i32() != 0 { return 8 }
    if test_slice_i32() != 0 { return 9 }
    if test_for_range_i32() != 0 { return 10 }
    println("All 10 A1 verification tests passed!")
    0
}
