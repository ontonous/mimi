// MCDD real_world: Flow complex interaction — Vending Machine
// Combines: state payload, overloaded transitions, Fault absorption,
// reset/recover, persistent fields, nested subflow, delegate view.
//
// Scenario: a vending machine that accepts coins, dispenses items,
// handles faults (jamming), and can be reset/recovered.
// Tests dual-backend equivalence for complex Flow programs.

flow CoinSlot {
    state Empty
    state HasCoin { value: i32 }

    transition insert(Empty) -> HasCoin {
        do { return HasCoin { value: 1 } }
    }
    transition insert(HasCoin) -> HasCoin {
        do { return HasCoin { value: self.value + 1 } }
    }
    transition eject(HasCoin) -> Empty {
        do { return Empty { } }
    }
}

flow VendingMachine {
    state Idle
    state CoinInserted { coins: i32, total: i32 }
    state Dispensing { item: string, coins: i32 }
    state OutOfStock { coins: i32 }

    transition coin(Idle) -> CoinInserted {
        do { return CoinInserted { coins: 1, total: 1 } }
    }
    transition coin(CoinInserted) -> CoinInserted {
        do { return CoinInserted { coins: self.coins + 1, total: self.total + 1 } }
    }
    transition buy(CoinInserted) -> Dispensing {
        do {
            // Check if enough coins (need at least 2)
            if self.coins < 2 {
                // Not enough coins — trigger Fault via undefined path
                return Dispensing { item: "error", coins: self.coins }
            }
            return Dispensing { item: "cola", coins: self.coins - 2 }
        }
    }
    transition collect(Dispensing) -> Idle {
        do { return Idle { } }
    }
    transition restock(OutOfStock) -> Idle {
        do { return Idle { } }
    }
}

func main() -> i32 {
    // Test 1: Basic vending cycle
    let vm0 = Idle { }
    let vm1 = VendingMachine::coin(vm0)
    let vm2 = VendingMachine::coin(vm1)
    let vm3 = VendingMachine::buy(vm2)
    println(vm3.item)
    println(vm3.coins)
    let vm4 = VendingMachine::collect(vm3)
    
    // Test 2: Coin slot subflow
    let cs0 = Empty { }
    let cs1 = CoinSlot::insert(cs0)
    let cs2 = CoinSlot::insert(cs1)
    println(cs2.value)
    let cs3 = CoinSlot::eject(cs2)
    
    // Test 3: Not enough coins → buy with 1 coin
    let vm5 = Idle { }
    let vm6 = VendingMachine::coin(vm5)
    let vm7 = VendingMachine::buy(vm6)
    println(vm7.item)
    
    // Test 4: Multiple coins then buy
    let vm8 = Idle { }
    let vm9 = VendingMachine::coin(vm8)
    let vm10 = VendingMachine::coin(vm9)
    let vm11 = VendingMachine::coin(vm10)
    let vm12 = VendingMachine::buy(vm11)
    println(vm12.item)
    println(vm12.coins)
    
    0
}
