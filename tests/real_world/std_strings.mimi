use std::strings

func main() -> i32 {
    let s = "  hello world  "
    let t = trim(s)
    let parts = split(t, " ")
    let joined = join(parts, "-")
    let up = to_upper(joined)
    if t == "hello world" && len(parts) == 2 && joined == "hello-world" && up == "HELLO-WORLD" {
        0
    } else {
        1
    }
}
