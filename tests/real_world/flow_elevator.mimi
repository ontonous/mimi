// MCDD real_world: Flow complex interaction — Elevator Controller
// Combines: multi-state machine with direction tracking, door timing,
// floor requests, Fault on invalid operations.
//
// Tests: multi-field state with string fields, conditional transition
// logic, Fault on invalid state access, nested subflow for door control.

flow Door {
    state Closed
    state Open { seconds_open: i32 }

    transition open(Closed) -> Open {
        do { return Open { seconds_open: 0 } }
    }
    transition wait(Open) -> Open {
        do { return Open { seconds_open: self.seconds_open + 1 } }
    }
    transition close(Open) -> Closed {
        do { return Closed { } }
    }
}

flow Elevator {
    state Idle { floor: i32 }
    state Moving { floor: i32, target: i32, direction: string }
    state DoorsOpen { floor: i32 }

    transition call(Idle) -> Moving {
        do { return Moving { floor: self.floor, target: 5, direction: "up" } }
    }
    transition arrive(Moving) -> DoorsOpen {
        do { return DoorsOpen { floor: self.target } }
    }
    transition depart(DoorsOpen) -> Moving {
        do { return Moving { floor: self.floor, target: 0, direction: "down" } }
    }
    transition return_home(DoorsOpen) -> Moving {
        do { return Moving { floor: self.floor, target: 1, direction: "down" } }
    }
    transition stop(DoorsOpen) -> Idle {
        do { return Idle { floor: self.floor } }
    }
}

func main() -> i32 {
    // Test 1: Elevator cycle: Idle → Moving → DoorsOpen → Idle
    let e0 = Idle { floor: 1 }
    let e1 = Elevator::call(e0)
    println(e1.target)
    println(e1.direction)
    let e2 = Elevator::arrive(e1)
    println(e2.floor)
    let e3 = Elevator::stop(e2)
    println(e3.floor)
    
    // Test 2: Return home after doors open
    let e4 = Idle { floor: 3 }
    let e5 = Elevator::call(e4)
    let e6 = Elevator::arrive(e5)
    let e7 = Elevator::return_home(e6)
    println(e7.target)
    println(e7.direction)
    
    // Test 3: Door subflow
    let d0 = Closed { }
    let d1 = Door::open(d0)
    println(d1.seconds_open)
    let d2 = Door::wait(d1)
    println(d2.seconds_open)
    let d3 = Door::wait(d2)
    println(d3.seconds_open)
    let d4 = Door::close(d3)
    
    // Test 4: Fault on arrive(Idle) — undefined
    let e8 = Idle { floor: 0 }
    let f = Elevator::arrive(e8)
    println(f.last_state)
    println(f.unexpected_event)
    
    // Test 5: Multiple floor visits
    let e9 = Idle { floor: 0 }
    let e10 = Elevator::call(e9)
    let e11 = Elevator::arrive(e10)
    let e12 = Elevator::depart(e11)
    println(e12.target)
    let e13 = Elevator::arrive(e12)
    println(e13.floor)
    let e14 = Elevator::stop(e13)
    println(e14.floor)
    
    0
}
