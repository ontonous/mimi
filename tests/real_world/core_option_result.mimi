func half(n: i32) -> Option<i32> {
    if n % 2 == 0 { Some(n / 2) } else { None }
}

func div(a: i32, b: i32) -> Result<i32, string> {
    if b == 0 { Err("divide by zero") } else { Ok(a / b) }
}

func main() -> i32 {
    let o = half(8)
    let r = div(10, 2)
    let ok = o.is_some() && o.unwrap_or(0) == 4 && r.is_ok() && r.unwrap_or(0) == 5
    if ok { 0 } else { 1 }
}
