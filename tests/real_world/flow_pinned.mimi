// MCDD real_world: Flow pinned — FFI anchor + cooperative watchdog (v0.29.32→0.29.43)
// Exercises pinned block: value side-effect through ptr, cooperative timeout.
// Success path: pinned block completes within timeout → normal continuation.
// v0.29.43: Timeout path now produces a delayed Fault value (not abort).
//   The Fault carries SystemTrace with last_state and pinned_timeout event.
//   Codegen still aborts on timeout=0 (sets pending flag first for runtime).
flow Buffer {
    state Active { data: i32 }

    transition use_pinned(Active) -> Active {
        do {
            pinned(self.data, timeout = 5000) |ptr| {
                // In real FFI, ptr would be passed to a C function.
                // Here we just verify ptr binding + scope isolation.
                let _ = ptr
            }
            return Active { data: self.data + 1 }
        }
    }

    transition no_timeout(Active) -> Active {
        do {
            pinned(self.data) |p| {
                let _ = p
            }
            return Active { data: self.data + 10 }
        }
    }
}

func main() -> i32 {
    // Success path with generous timeout
    let s0 = Active { data: 100 }
    let s1 = Buffer::use_pinned(s0)
    println(s1.data)
    let s2 = Buffer::no_timeout(s1)
    println(s2.data)
    0
}
