type Res { Ok(i32) | Err(string) }

func parse_pos(s: string) -> Res {
    let p = str_parse_int(s)
    if p.0 {
        if p.1 > 0 { Ok(p.1) } else { Err("not positive") }
    } else {
        Err("not a number")
    }
}

func half_of(s: string) -> Res {
    let n = parse_pos(s)?
    if n % 2 == 0 { Ok(n / 2) } else { Err("odd") }
}

func main() -> i32 {
    match half_of("20") {
        Ok(10) => 0,
        _ => 1
    }
}
