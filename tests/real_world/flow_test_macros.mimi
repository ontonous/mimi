// MCDD real_world: Test engineering — assert_state! + inject_fault! (v0.29.38)
// Tests: assert_state verifies flow state in the interpreter.
// LLVM codegen rejects this file until runtime state identity is available.

flow Counter {
    state Zero { count: i32 }
    state Positive { count: i32 }

    transition inc(Zero) -> Positive {
        do {
            return Positive { count: self.count + 1 }
        }
    }
    transition inc(Positive) -> Positive {
        do {
            return Positive { count: self.count + 1 }
        }
    }
}

func main() -> i32 {
    let s0 = Zero { count: 0 }
    // Verify initial state.
    assert_state(s0, "Zero")

    let s1 = Counter::inc(s0)
    // Verify state transition
    assert_state(s1, "Positive")
    println(s1.count)

    0
}
