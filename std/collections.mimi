pub func sum(xs: List<i32>) -> i32 {
    let mut total = 0
    for x in xs {
        total = total + x
    }
    total
}

pub func contains<T>(xs: List<T>, x: T) -> bool {
    for elem in xs {
        if elem == x {
            return true
        }
    }
    false
}

pub func is_empty<T>(xs: List<T>) -> bool {
    len(xs) == 0
}
