// identity: Returns the input unchanged.
pub func identity<T>(x: T) -> T {
    x
}

// const_val: Ignores second argument, returns first.
pub func const_val<T, U>(x: T, _y: U) -> T {
    x
}

// is_even: Returns true if x is divisible by 2.
pub func is_even(x: i32) -> bool {
    x % 2 == 0
}

// is_odd: Returns true if x is not divisible by 2.
pub func is_odd(x: i32) -> bool {
    x % 2 != 0
}

// is_positive: Returns true if x > 0.
pub func is_positive(x: i32) -> bool {
    x > 0
}

// is_negative: Returns true if x < 0.
pub func is_negative(x: i32) -> bool {
    x < 0
}

// is_zero: Returns true if x == 0.
pub func is_zero(x: i32) -> bool {
    x == 0
}

// negate: Logical NOT for booleans.
pub func negate(b: bool) -> bool {
    !b
}

// min3: Returns the smallest of three integers.
pub func min3(a: i32, b: i32, c: i32) -> i32 {
    if a <= b {
        if a <= c { a } else { c }
    } else {
        if b <= c { b } else { c }
    }
}

// max3: Returns the largest of three integers.
pub func max3(a: i32, b: i32, c: i32) -> i32 {
    if a >= b {
        if a >= c { a } else { c }
    } else {
        if b >= c { b } else { c }
    }
}

// swap: Swaps the positions of two values.
pub func swap<T, U>(a: T, b: U) -> (U, T) {
    (b, a)
}

// clamp: Restricts value to [min_val, max_val] inclusive.
pub func clamp(value: i32, min_val: i32, max_val: i32) -> i32 {
    if value < min_val {
        min_val
    } else if value > max_val {
        max_val
    } else {
        value
    }
}

// clamp_float: Restricts floating-point value to [min_val, max_val] inclusive.
pub func clamp_float(value: f64, min_val: f64, max_val: f64) -> f64 {
    if value < min_val {
        min_val
    } else if value > max_val {
        max_val
    } else {
        value
    }
}

// lerp: Linear interpolation: a + (b - a) * t.
pub func lerp(a: f64, b: f64, t: f64) -> f64 {
    a + (b - a) * t
}

// compose: Returns f ∘ g (function composition).
pub func compose<T, U, V>(f: func(U) -> V, g: func(T) -> U) -> func(T) -> V {
    fn(x: T) -> V { f(g(x)) }
}

// pipe: Applies f to x (pipeline operator).
pub func pipe<T, U>(x: T, f: func(T) -> U) -> U {
    f(x)
}

// tap: Calls f(x) for side effects, then returns x.
pub func tap<T>(x: T, f: func(T) -> ()) -> T {
    f(x)
    x
}

// flip: Returns a function with the first two arguments swapped.
pub func flip<T, U, V>(f: func(T, U) -> V) -> func(U, T) -> V {
    fn(a: U, b: T) -> V { f(b, a) }
}

// apply: Alias for calling f(x).
pub func apply<T, U>(f: func(T) -> U, x: T) -> U {
    f(x)
}

// konst: Returns a function that always returns x regardless of argument.
pub func konst<T, U>(x: T) -> func(U) -> T {
    fn(_: U) -> T { x }
}

// fail: Prints an error message and exits with code 1.
pub func fail(msg: string) -> () {
    println("ERROR:", msg)
    exit(1)
}

// unreachable: Prints error and exits — marks unreachable code paths.
pub func unreachable() -> () {
    println("ERROR: reached unreachable code")
    exit(1)
}

// todo: Prints message and exits — marks unimplemented code paths.
pub func todo() -> () {
    println("TODO: unimplemented")
    exit(1)
}

