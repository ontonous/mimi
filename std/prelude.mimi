// default_i32: Returns 0.
pub func default_i32() -> i32 { 0 }

// default_f64: Returns 0.0.
pub func default_f64() -> f64 { 0.0 }

// default_bool: Returns false.
pub func default_bool() -> bool { false }

// default_string: Returns empty string.
pub func default_string() -> string { "" }

// increment: Returns x + 1.
pub func increment(x: i32) -> i32 { x + 1 }

// decrement: Returns x - 1.
pub func decrement(x: i32) -> i32 { x - 1 }

// double: Returns x * 2.
pub func double(x: i32) -> i32 { x * 2 }

// triple: Returns x * 3.
pub func triple(x: i32) -> i32 { x * 3 }

// half: Returns x / 2 (integer division).
pub func half(x: i32) -> i32 { x / 2 }

// sqr: Returns x * x.
pub func sqr(x: i32) -> i32 { x * x }

// cube_int: Returns x * x * x.
pub func cube_int(x: i32) -> i32 { x * x * x }

// eq: Equality check via the Eq trait.
pub func eq<T>(a: T, b: T) -> bool where T: Eq {
    a == b
}

// not_eq: Inequality check via the Eq trait.
pub func not_eq<T>(a: T, b: T) -> bool where T: Eq {
    a != b
}

// not: Boolean NOT.
pub func bool_not(b: bool) -> bool {
    !b
}

// assert_msg: If condition is false, prints message and exits with code 1.
pub func assert_msg(cond: bool, msg: string) {
    if !cond {
        println("ASSERTION FAILED:", msg)
        exit(1)
    }
    ()
}

// repeat_action: Calls f(i) for i in 0..n.
pub func repeat_action(n: i32, f: func(i32) -> ()) {
    let mut ra_i = 0
    while ra_i < n {
        f(ra_i)
        ra_i += 1
    }
}

// times: Calls f() n times.
pub func times(n: i32, f: func() -> ()) {
    let mut t_i = 0
    while t_i < n {
        f()
        t_i += 1
    }
}

// to_int_safe: Parses s as integer, returns default on failure.
pub func to_int_safe(s: string, default: i32) -> i32 {
    let tis_parsed = str_parse_int(s)
    if tis_parsed.0 { tis_parsed.1 } else { default }
}

// to_float_safe: Parses s as float, returns default on failure.
pub func to_float_safe(s: string, default: f64) -> f64 {
    let tfs_parsed = str_parse_float(s)
    if tfs_parsed.0 { tfs_parsed.1 } else { default }
}
