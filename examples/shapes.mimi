// Mimi v0.2 示例：ADT + match

type Shape {
    Circle(f64)
    Rectangle(f64, f64)
}

func area(s: Shape) -> f64 {
    match s {
        Circle(r) => 3.14159 * r * r,
        Rectangle(w, h) => w * h,
    }
}

func main() -> f64 {
    let c = Circle(2.0);
    let r = Rectangle(3.0, 4.0);
    return area(c) + area(r);
}
