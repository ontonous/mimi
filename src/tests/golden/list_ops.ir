define i64 @main() {
entry:
  %list = alloca { i64, ptr }, align 8
  %heap_slot_null_init = getelementptr inbounds { i64, ptr }, ptr %list, i32 0, i32 1
  store ptr null, ptr %heap_slot_null_init, align 8
  %malloc_call = call ptr @malloc(i64 24)
  %elem = getelementptr inbounds i64, ptr %malloc_call, i64 0
  store i64 1, ptr %elem, align 4
  %elem1 = getelementptr inbounds i64, ptr %malloc_call, i64 1
  store i64 2, ptr %elem1, align 4
  %elem2 = getelementptr inbounds i64, ptr %malloc_call, i64 2
  store i64 3, ptr %elem2, align 4
  %list_len = getelementptr inbounds { i64, ptr }, ptr %list, i32 0, i32 0
  store i64 3, ptr %list_len, align 4
  %list_data = getelementptr inbounds { i64, ptr }, ptr %list, i32 0, i32 1
  store ptr %malloc_call, ptr %list_data, align 8
  %xs = alloca ptr, align 8
  store ptr %list, ptr %xs, align 8
  %xs3 = load ptr, ptr %xs, align 8
  %list.len_check = getelementptr inbounds { i64, ptr }, ptr %xs3, i32 0, i32 0
  %list_len4 = getelementptr inbounds { i64, ptr }, ptr %xs3, i32 0, i32 0
  %list_len_val = load i64, ptr %list_len4, align 4
  %oob = icmp uge i64 0, %list_len_val
  br i1 %oob, label %bounds_fail, label %bounds_ok

bounds_ok:                                        ; preds = %bounds_fail, %entry
  %list.data = getelementptr inbounds { i64, ptr }, ptr %xs3, i32 0, i32 1
  %data = load ptr, ptr %list.data, align 8
  %elem5 = getelementptr inbounds i64, ptr %data, i64 0
  %elem_val = load i64, ptr %elem5, align 4
  %xs6 = load ptr, ptr %xs, align 8
  %list.len_check7 = getelementptr inbounds { i64, ptr }, ptr %xs6, i32 0, i32 0
  %list_len8 = getelementptr inbounds { i64, ptr }, ptr %xs6, i32 0, i32 0
  %list_len_val9 = load i64, ptr %list_len8, align 4
  %oob12 = icmp uge i64 1, %list_len_val9
  br i1 %oob12, label %bounds_fail11, label %bounds_ok10

bounds_fail:                                      ; preds = %entry
  call void @mimi_runtime_abort(ptr @oob_msg)
  br label %bounds_ok

bounds_ok10:                                      ; preds = %bounds_fail11, %bounds_ok
  %list.data13 = getelementptr inbounds { i64, ptr }, ptr %xs6, i32 0, i32 1
  %data14 = load ptr, ptr %list.data13, align 8
  %elem15 = getelementptr inbounds i64, ptr %data14, i64 1
  %elem_val16 = load i64, ptr %elem15, align 4
  %add = add i64 %elem_val, %elem_val16
  %xs17 = load ptr, ptr %xs, align 8
  %list.len_check18 = getelementptr inbounds { i64, ptr }, ptr %xs17, i32 0, i32 0
  %list_len19 = getelementptr inbounds { i64, ptr }, ptr %xs17, i32 0, i32 0
  %list_len_val20 = load i64, ptr %list_len19, align 4
  %oob23 = icmp uge i64 2, %list_len_val20
  br i1 %oob23, label %bounds_fail22, label %bounds_ok21

bounds_fail11:                                    ; preds = %bounds_ok
  call void @mimi_runtime_abort(ptr @oob_msg.1)
  br label %bounds_ok10

bounds_ok21:                                      ; preds = %bounds_fail22, %bounds_ok10
  %list.data24 = getelementptr inbounds { i64, ptr }, ptr %xs17, i32 0, i32 1
  %data25 = load ptr, ptr %list.data24, align 8
  %elem26 = getelementptr inbounds i64, ptr %data25, i64 2
  %elem_val27 = load i64, ptr %elem26, align 4
  %add28 = add i64 %add, %elem_val27
  %heap_slot_gep = getelementptr inbounds { i64, ptr }, ptr %list, i32 0, i32 1
  %heap_slot = load ptr, ptr %heap_slot_gep, align 8
  call void @free(ptr %heap_slot)
  ret i64 %add28

bounds_fail22:                                    ; preds = %bounds_ok10
  call void @mimi_runtime_abort(ptr @oob_msg.2)
  br label %bounds_ok21
}

