; ModuleID = 'golden_test'
source_filename = "golden_test"

declare i32 @printf(ptr, ...)

declare i32 @puts(ptr)

declare ptr @malloc(i64)

declare void @free(ptr)

declare i64 @strlen(ptr)

declare i32 @strcmp(ptr, ptr)

declare ptr @strcpy(ptr, ptr)

declare ptr @strcat(ptr, ptr)

declare ptr @memcpy(ptr, ptr, i64)

declare ptr @realloc(ptr, i64)

declare i32 @fprintf(ptr, ptr, ...)

declare i64 @sprintf(ptr, ptr, ...)

declare void @exit(i32)

declare i32 @pthread_create(ptr, ptr, ptr, ptr)

declare i32 @pthread_join(ptr, ptr)

declare i64 @mimi_map_new()

declare void @mimi_map_destroy(i64)

declare i64 @mimi_map_size(i64)

declare i32 @mimi_map_has_key(i64, ptr)

declare i64 @mimi_map_get(i64, ptr)

declare void @mimi_map_set(i64, ptr, i64)

declare i32 @mimi_map_remove(i64, ptr)

declare i64 @mimi_map_from_list(ptr, ptr, i64)

declare ptr @mimi_map_keys(i64)

declare ptr @mimi_map_values(i64)

declare ptr @mimi_value_type_name(i64)

declare ptr @mimi_str_split(ptr, ptr)

declare ptr @mimi_str_join(ptr, ptr)

declare ptr @mimi_str_concat(ptr, ptr)

declare ptr @mimi_str_replace(ptr, ptr, ptr)

declare void @mimi_try_exit(i64)

declare void @mimi_try_exit_str(ptr, i64)

declare i64 @mimi_shared_retain(i64)

declare void @mimi_shared_release(i64)

declare ptr @mimi_rc_alloc(i64)

declare void @mimi_rc_retain(ptr)

declare void @mimi_rc_release(ptr)

declare void @mimi_rc_weak_retain(ptr)

declare void @mimi_rc_weak_release(ptr)

declare ptr @mimi_rc_upgrade(ptr)

declare i32 @mimi_cap_check(i64, ptr)

declare i64 @mimi_cap_register(ptr)

declare i32 @mimi_cap_consume(i64, ptr)

declare ptr @mimi_tuple_serialize(ptr, i64, ptr)

declare i64 @mimi_tuple_deserialize(ptr, i64, ptr, ptr)

declare void @mimi_pool_submit(ptr, ptr)

declare void @mimi_pool_join_all()

declare i64 @mimi_now()

declare i64 @mimi_now_ms()

declare void @mimi_sleep(i64)

declare ptr @mimi_getenv(ptr)

declare void @mimi_args_init(i64, ptr)

declare i64 @mimi_args_count()

declare ptr @mimi_args_get(i64)

declare i32 @mimi_is_valid_json(ptr)

declare ptr @mimi_from_json(ptr)

declare ptr @json_get_string(ptr, ptr)

declare i64 @json_get_int(ptr, ptr)

declare ptr @json_get_element(ptr, i64)

declare i64 @mimi_socket(i64, i64, i64)

declare i64 @mimi_connect(i64, ptr, i64)

declare i64 @mimi_bind(i64, i64)

declare i64 @mimi_listen(i64, i64)

declare i64 @mimi_accept(i64)

declare i64 @mimi_send(i64, ptr, i64)

declare ptr @mimi_recv(i64, i64, ptr)

declare i64 @mimi_close(i64)

declare ptr @mimi_http_get(ptr)

declare ptr @mimi_http_post(ptr, ptr)

define i64 @main() {
entry:
  %x = alloca i64, align 8
  store i64 5, ptr %x, align 4
  %y = alloca i64, align 8
  store i64 10, ptr %y, align 4
  %x1 = load i64, ptr %x, align 4
  %gt = icmp sgt i64 %x1, 0
  br i1 %gt, label %then, label %else

then:                                             ; preds = %entry
  %y2 = load i64, ptr %y, align 4
  %gt3 = icmp sgt i64 %y2, 0
  br i1 %gt3, label %blt_then, label %blt_else

else:                                             ; preds = %entry
  %y7 = load i64, ptr %y, align 4
  br label %ifcont

ifcont:                                           ; preds = %else, %blt_merge
  %if_result = phi i64 [ %if_lastval, %blt_merge ], [ %y7, %else ]
  ret i64 %if_result

blt_then:                                         ; preds = %then
  %x4 = load i64, ptr %x, align 4
  %y5 = load i64, ptr %y, align 4
  %add = add i64 %x4, %y5
  br label %blt_merge

blt_else:                                         ; preds = %then
  %x6 = load i64, ptr %x, align 4
  br label %blt_merge

blt_merge:                                        ; preds = %blt_else, %blt_then
  %if_lastval = phi i64 [ %add, %blt_then ], [ %x6, %blt_else ]
  br label %ifcont
}
