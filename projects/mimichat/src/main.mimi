func test_list_ops() -> TestResult {
    let mut items: List<string> = []
    if len(items) != 0 { return test_fail("list_ops", "Expected empty list") }
    push(items, "a"); push(items, "b"); push(items, "c")
    if len(items) != 3 { return test_fail("list_ops", "Expected len=3") }
    if items[0] != "a" { return test_fail("list_ops", "Expected items[0]='a'") }
    if !list_contains_string(items, "b") { return test_fail("list_ops", "Expected contains 'b'") }
    if list_contains_string(items, "z") { return test_fail("list_ops", "Expected not contains 'z'") }
    test_pass("list_ops")
}

