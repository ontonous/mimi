func test_user_manager_history_trim() -> TestResult {
    let um = UserManager.spawn()
    let mut i = 0
    while i < 20 { um.push_history("{\"msg\":" + to_string(i) + "}"); i = i + 1 }
    let h = um.get_history(100)
    if len(h) != 20 { return test_fail("user_manager_history_trim", "Expected 20 entries before trim, got " + to_string(len(h))) }
    let um2 = UserManager.spawn()
    i = 0
    while i < 1100 { um2.push_history("{\"msg\":" + to_string(i) + "}"); i = i + 1 }
    let h2 = um2.get_history(2000)
    if len(h2) > 1050 { return test_fail("user_manager_history_trim", "Expected trim to limit history to <=1000, got " + to_string(len(h2))) }
    test_pass("user_manager_history_trim")
}

func run_all_tests() -> i32 {
    println("MimiChat Test Suite v0.1.0")
    println("================================")
    let mut results: List<TestResult> = []
    push(results, test_is_blank())
    push(results, test_is_valid_nick())
    push(results, test_is_valid_room_name())
    push(results, test_escape_json_string())
    push(results, test_list_ops())
    push(results, test_list_contains_edge_cases())
    push(results, test_format_timestamp())
    push(results, test_format_timestamp_zeros())
    push(results, test_cmd_get_string_default())
    push(results, test_safe_parse_int())
    push(results, test_client_cmd())
    push(results, test_client_cmd_str())
    push(results, test_encode_chat_msg())
    push(results, test_encode_private_msg())
    push(results, test_encode_join_msg())
    push(results, test_encode_leave_msg())
    push(results, test_encode_error_msg())
    push(results, test_encode_nick_msg())
    push(results, test_encode_rooms_msg())
    push(results, test_encode_users_msg())
    push(results, test_encode_ok_msg())
    push(results, test_encode_pong_msg())
    push(results, test_encode_topic_msg())
    push(results, test_encode_history_msg())
    push(results, test_encode_system_msg())
    push(results, test_parse_client_command())
    push(results, test_safe_parse_int())
    push(results, test_parse_client_command())
    push(results, test_encode_chat_msg())
    push(results, test_encode_system_msg())
    push(results, test_user_manager_basic())
    push(results, test_user_manager_nick_collision())
    push(results, test_user_manager_change_nick())
    push(results, test_room_manager_basic())
    push(results, test_room_manager_join_leave())
    push(results, test_room_manager_create())
    push(results, test_message_store_basic())
    push(results, test_message_store_rollover())
    push(results, test_user_manager_history())
    push(results, test_room_manager_topic())
    push(results, test_room_manager_motd())
    push(results, test_user_manager_history_trim())
    push(results, test_is_blank_edge())
    push(results, test_user_manager_set_room())
    push(results, test_user_manager_get_room())
    push(results, test_user_manager_list_nicks())
    push(results, test_user_manager_unregister())
    push(results, test_user_manager_get_nick())
    push(results, test_user_manager_get_fd())
    push(results, test_room_manager_count())
    push(results, test_room_manager_duplicate_join())
    push(results, test_room_manager_member_count())
    push(results, test_store_add_rollover_verify())
    push(results, test_store_add_exact_max())
    push(results, test_store_add_single())
    push(results, test_store_add_preserves_order())
    push(results, test_safe_substring_basic())
    push(results, test_safe_substring_edge())
    push(results, test_format_timestamp_large())
    push(results, test_user_manager_clear())
    push(results, test_room_manager_clear())
    push(results, test_encode_empty_rooms())
    push(results, test_encode_empty_users())
    push(results, test_encode_empty_history())
    push(results, test_integration_basic())
    let total = len(results)
    let mut passed_count = 0
    for r in results {
        if r.passed { passed_count = passed_count + 1 }
    }
    println("")
    println("================================")
    println("Results: " + to_string(passed_count) + "/" + to_string(total) + " passed")
    println("")
    for r in results {
        let status = if r.passed { "PASS" } else { "FAIL" }
        println("  [" + status + "] " + r.name)
        if !r.passed { println("        " + r.message) }
    }
    println("")
    if passed_count == total { println("All tests passed!"); 0 }
    else { println(to_string(total - passed_count) + " test(s) failed."); 1 }
}

// ═══════════════════════════════════════════════════════════════════════════════
// Section 11: Main Entry Point
// ═══════════════════════════════════════════════════════════════════════════════

func print_global_usage() {
    println("MimiChat v0.1.0 - Multi-User Chat System")
    println("")
    println("Usage:")
    println("  mimichat server [options]        Start chat server")
    println("  mimichat client [host] [port]    Start chat client")
    println("  mimichat test                    Run automated tests")
    println("  mimichat --help                  Show this help")
    println("")
    println("Examples:")
    println("  mimichat server")
    println("  mimichat server --port 8888 --max-clients 100")
    println("  mimichat client 127.0.0.1 7777")
    println("  mimichat test")
}

func main() -> i32 {
    let arg_list = args()
    if len(arg_list) == 0 { print_global_usage(); return 0 }
    let mode = str_to_lower(arg_list[0])
    if mode == "server" || mode == "serve" || mode == "s" {
        let mut server_args: List<string> = []
        let mut i = 1
        while i < len(arg_list) { push(server_args, arg_list[i]); i = i + 1 }
        let config = parse_server_args(server_args)
        println("Starting MimiChat server on port " + to_string(config.port) + "...")
        let (srv_fd, um, rm) = init_server(config)
        if srv_fd >= 0 { run_server_loop(srv_fd, um, rm, config) } else { 1 }
    } else if mode == "client" || mode == "cli" || mode == "c" {
        let host = if len(arg_list) > 1 { arg_list[1] } else { "127.0.0.1" }
        let port = if len(arg_list) > 2 { safe_parse_int(arg_list[2], 7777) } else { 7777 }
        let nick = if len(arg_list) > 3 { arg_list[3] } else { "user_" + to_string(now_ms() % 10000) }
        run_client(host, port, nick)
    } else if mode == "test" || mode == "tests" || mode == "t" || mode == "--test" {
        run_all_tests()
    } else if mode == "--help" || mode == "-h" || mode == "help" { print_global_usage(); 0 }
    else { println("Unknown mode: " + mode); print_global_usage(); 1 }
}
