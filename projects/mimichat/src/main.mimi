func test_pass(name: string) -> TestResult { TestResult { name: name, passed: true, message: "" } }
func test_fail(name: string, msg: string) -> TestResult { TestResult { name: name, passed: false, message: msg } }

func test_is_blank() -> TestResult {
    if !is_blank("") { return test_fail("is_blank", "Expected empty string to be blank") }
    if !is_blank("  ") { return test_fail("is_blank", "Expected whitespace to be blank") }
    if is_blank("a") { return test_fail("is_blank", "Expected 'a' not to be blank") }
    test_pass("is_blank")
}

