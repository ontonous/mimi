    if is_valid_nick("a") { return test_fail("is_valid_nick", "Expected 'a' (len=1) to be invalid") }
    if is_valid_nick("") { return test_fail("is_valid_nick", "Expected empty nick to be invalid") }
    if is_valid_nick("hello world") { return test_fail("is_valid_nick", "Expected nick with space to be invalid") }
    test_pass("is_valid_nick")
}

