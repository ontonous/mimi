func test_safe_substring_basic() -> TestResult {
    let s1 = safe_substring("hello", 0, 5)
    if s1 != "hello" { return test_fail("safe_substring_basic", "Expected 'hello', got '" + s1 + "'") }
    let s2 = safe_substring("hello", 0, 3)
    if s2 != "hel" { return test_fail("safe_substring_basic", "Expected 'hel', got '" + s2 + "'") }
    let s3 = safe_substring("hello", 1, 4)
    if s3 != "ell" { return test_fail("safe_substring_basic", "Expected 'ell', got '" + s3 + "'") }
    test_pass("safe_substring_basic")
}

func test_safe_substring_edge() -> TestResult {
    let s1 = safe_substring("abc", 0, 0)
    if s1 != "" { return test_fail("safe_substring_edge", "Expected empty for 0 len") }
    let s2 = safe_substring("abc", 10, 5)
    if s2 != "" { return test_fail("safe_substring_edge", "Expected empty for start>len") }
    let s3 = safe_substring("abc", 0, 10)
    if s3 != "abc" { return test_fail("safe_substring_edge", "Expected 'abc', got '" + s3 + "'") }
    let s4 = safe_substring("", 0, 5)
    if s4 != "" { return test_fail("safe_substring_edge", "Expected empty for empty string") }
    test_pass("safe_substring_edge")
}

