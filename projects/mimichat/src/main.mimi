    test_pass("room_manager_create")
}

func test_message_store_basic() -> TestResult {
    let store = create_store(100, "/tmp/mimichat_test_history.json")
    if len(store.buffer) != 0 { return test_fail("message_store_basic", "Expected empty store") }
    let s1 = store_add(store, "{\"type\":\"chat\",\"text\":\"hello\"}")
    if len(s1.buffer) != 1 { return test_fail("message_store_basic", "Expected 1 message after add") }
    let s2 = store_add(s1, "{\"type\":\"chat\",\"text\":\"world\"}")
    if len(s2.buffer) != 2 { return test_fail("message_store_basic", "Expected 2 messages after add") }
    test_pass("message_store_basic")
}

func test_message_store_rollover() -> TestResult {
    let store = create_store(5, "/tmp/mimichat_test_rollover.json")
    let mut s = store
    let mut i = 0
    while i < 10 { s = store_add(s, "{\"msg\":" + to_string(i) + "}"); i = i + 1 }
    if len(s.buffer) != 5 { return test_fail("message_store_rollover", "Expected 5 messages after rollover, got " + to_string(len(s.buffer))) }
    test_pass("message_store_rollover")
}

func test_integration_basic() -> TestResult {
    let um = UserManager.spawn()
    let rm = RoomManager.spawn()
    rm.create("lobby")
    let reg = um.register("TestUser", 999 as i64)
    if reg != "ok" { return test_fail("integration_basic", "Registration failed: " + reg) }
    let join_r = rm.join("lobby", "TestUser")
    if join_r != "ok" { return test_fail("integration_basic", "Join failed: " + join_r) }
    um.set_room("TestUser", "lobby")
    let members = rm.get_members("lobby")
    if !list_contains_string(members, "TestUser") { return test_fail("integration_basic", "Expected TestUser in room members") }
    let msg = encode_chat_msg("TestUser", "lobby", "Integration test message", now_ms())
    if !json_is_valid(msg) { return test_fail("integration_basic", "Invalid chat message JSON") }
    let msg_type = json_get_string(msg, "type")
    if msg_type != SVR_CHAT() { return test_fail("integration_basic", "Expected type=chat") }
    let leave_r = rm.leave("lobby", "TestUser")
    if leave_r != "ok" { return test_fail("integration_basic", "Leave failed: " + leave_r) }
    let unreg_result = um.unregister(999 as i64)
    if unreg_result == "not found" { return test_fail("integration_basic", "Unregister failed") }
    test_pass("integration_basic")
}

func test_user_manager_history() -> TestResult {
