func test_list_contains_edge_cases() -> TestResult {
    let empty: List<string> = []
    if list_contains_string(empty, "x") { return test_fail("list_contains_edge_cases", "Empty list should not contain anything") }
    let single = ["only"]
    if !list_contains_string(single, "only") { return test_fail("list_contains_edge_cases", "Should find 'only'") }
    if list_contains_string(single, "ONLY") { return test_fail("list_contains_edge_cases", "Should be case-sensitive") }
    let multi = ["a", "b", "c"]
    let mut count = 0
    for x in multi { if x == "a" || x == "b" || x == "c" { count = count + 1 } }
    if count != 3 { return test_fail("list_contains_edge_cases", "Expected 3 items") }
    test_pass("list_contains_edge_cases")
}

