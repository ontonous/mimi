func test_user_manager_basic() -> TestResult {
    let um = UserManager.spawn()
    um.register("Alice", 100 as i64)
    if !um.nick_exists("Alice") { return test_fail("user_manager_basic", "Expected Alice to exist") }
    let nick = um.get_nick(100 as i64)
    if nick != "Alice" { return test_fail("user_manager_basic", "Expected get_nick=Alice, got '" + nick + "'") }
    let fd = um.get_fd("Alice")
    if fd != 100 as i64 { return test_fail("user_manager_basic", "Expected get_fd=100, got " + to_string(fd)) }
    let cnt = um.count()
    if cnt != 1 { return test_fail("user_manager_basic", "Expected count=1, got " + to_string(cnt)) }
    test_pass("user_manager_basic")
}

func test_user_manager_nick_collision() -> TestResult {
    let um = UserManager.spawn()
    um.register("Alice", 100 as i64)
    let r2 = um.register("Alice", 200 as i64)
    if r2 == "ok" { return test_fail("user_manager_nick_collision", "Expected collision for duplicate nick") }
    let r3 = um.register("alice", 300 as i64)
    if r3 == "ok" { return test_fail("user_manager_nick_collision", "Expected collision for case-insensitive duplicate") }
    test_pass("user_manager_nick_collision")
}

func test_user_manager_change_nick() -> TestResult {
    let um = UserManager.spawn()
    um.register("Alice", 100 as i64)
    let old_nick_val = um.change_nick(100 as i64, "Alice99")
    if old_nick_val == "" || old_nick_val == "ok" { return test_fail("user_manager_change_nick", "Expected old nick returned") }
    if um.nick_exists("Alice") { return test_fail("user_manager_change_nick", "Alice should not exist after rename") }
    if !um.nick_exists("Alice99") { return test_fail("user_manager_change_nick", "Alice99 should exist") }
    let new_nick = um.get_nick(100 as i64)
    if new_nick != "Alice99" { return test_fail("user_manager_change_nick", "Expected get_nick=Alice99, got '" + new_nick + "'") }
    test_pass("user_manager_change_nick")
}

func test_room_manager_basic() -> TestResult {
    let rm = RoomManager.spawn()
    let create_r = rm.create("lobby")
    if create_r != "ok" { return test_fail("room_manager_basic", "Create lobby failed: " + create_r) }
    let rooms = rm.list_rooms()
    if !list_contains_string(rooms, "lobby") { return test_fail("room_manager_basic", "Expected lobby in rooms") }
    let cnt = rm.count()
    if cnt < 1 { return test_fail("room_manager_basic", "Expected count >= 1") }
    test_pass("room_manager_basic")
}

func test_room_manager_join_leave() -> TestResult {
    let rm = RoomManager.spawn()
    rm.create("lobby")
    let r1 = rm.join("lobby", "Alice")
    if r1 != "ok" { return test_fail("room_manager_join_leave", "Join failed: " + r1) }
    if !rm.is_member("lobby", "Alice") { return test_fail("room_manager_join_leave", "Expected Alice to be member") }
    let members = rm.get_members("lobby")
    if !list_contains_string(members, "Alice") { return test_fail("room_manager_join_leave", "Expected Alice in members list") }
    let r2 = rm.leave("lobby", "Alice")
    if r2 != "ok" { return test_fail("room_manager_join_leave", "Leave failed: " + r2) }
    if rm.is_member("lobby", "Alice") { return test_fail("room_manager_join_leave", "Expected Alice to not be member after leave") }
    test_pass("room_manager_join_leave")
}

func test_room_manager_create() -> TestResult {
    let rm = RoomManager.spawn()
