func test_parse_client_command() -> TestResult {
    let c1 = parse_client_command("/join general")
    if !cmd_is(c1, CMD_JOIN()) { return test_fail("parse_client_command", "Expected cmd=join") }
    let room1 = cmd_get_string(c1, "room", "")
    if room1 != "general" { return test_fail("parse_client_command", "Expected room=general, got '" + room1 + "'") }
    let c2 = parse_client_command("/nick Alice")
    if !cmd_is(c2, CMD_NICK()) { return test_fail("parse_client_command", "Expected cmd=nick") }
    let n2 = cmd_get_string(c2, "name", "")
    if n2 != "Alice" { return test_fail("parse_client_command", "Expected name=Alice, got '" + n2 + "'") }
    let c3 = parse_client_command("hello world")
    if !cmd_is(c3, CMD_MSG()) { return test_fail("parse_client_command", "Expected cmd=msg for plain text") }
    let t3 = cmd_get_string(c3, "text", "")
    if t3 != "hello world" { return test_fail("parse_client_command", "Expected text=hello world, got '" + t3 + "'") }
    let c4 = parse_client_command("{\"cmd\":\"join\",\"room\":\"test\"}")
    if !cmd_is(c4, CMD_JOIN()) { return test_fail("parse_client_command", "Expected cmd=join from JSON") }
    let room4 = cmd_get_string(c4, "room", "")
    if room4 != "test" { return test_fail("parse_client_command", "Expected room=test from JSON, got '" + room4 + "'") }
    let c5 = parse_client_command("{\"cmd\":\"private\",\"to\":\"bob\",\"text\":\"hi\"}")
    if !cmd_is(c5, CMD_PRIVATE()) { return test_fail("parse_client_command", "Expected cmd=private from JSON") }
    let to5 = cmd_get_string(c5, "to", "")
    if to5 != "bob" { return test_fail("parse_client_command", "Expected to=bob, got '" + to5 + "'") }
    test_pass("parse_client_command")
}

